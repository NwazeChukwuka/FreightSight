{
  "name": "freightsight-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "node scripts/build-production.js build",
    "build:analyze": "node scripts/build-production.js analyze",
    "start": "next start",
    "server": "nodemon server.js",
    "server:prod": "node server-ssl.js",
    "backup": "node scripts/backup.js",
    "backup:full": "node scripts/backup.js full",
    "backup:schedule": "node scripts/backup.js schedule",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next dist build logs",
    "deploy": "npm run build:prod && npm run backup:full",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop freightSight",
    "pm2:restart": "pm2 restart freightSight",
    "pm2:logs": "pm2 logs freightSight"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "ai": "latest",
    "autoprefixer": "^10.5.0",
    "axios": "latest",
    "bcryptjs": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "latest",
    "crypto": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "latest",
    "lucide-react": "^0.454.0",
    "mongoose": "latest",
    "next": "16.0.0",
    "next-themes": "latest",
    "node-cron": "^3.0.3",
    "nodemailer": "latest",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "latest",
    "redis": "^4.6.10",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "node-cron": "^3.0.3",
    "nodemon": "^2.0.22",
    "postcss": "^8.5.12",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.1.9",
    "typescript": "^5",
    "vitest": "^1.0.4",
    "@next/bundle-analyzer": "^14.0.4",
    "compression-webpack-plugin": "^10.0.0",
    "webpack-bundle-analyzer": "^4.9.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.0.4"
  },
  "optionalDependencies": {
    "aws-sdk": "^2.1500.0",
    "pm2": "^5.3.0"
  }
}
